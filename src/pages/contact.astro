---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Contact — Nick Battaglia"
  description="Get in touch with Nick Battaglia — email, LinkedIn, or GitHub."
>

  <section class="container pt-20 pb-16 max-w-lg">
    <p class="pill mb-5">Contact</p>
    <h1 class="font-serif text-4xl font-light text-text mb-4">Get in touch</h1>
    <p class="text-text-dim leading-relaxed mb-10">
      I'm always happy to talk about legal AI, M&amp;A, data science, or anything at
      their intersection. Reach me through any of the channels below.
    </p>

    <div class="space-y-4">
      <a
        href="mailto:dvbattag@iu.edu"
        class="card flex items-center gap-4 hover:border-accent/40 group"
      >
        <span class="text-2xl">&#9993;</span>
        <div>
          <p class="text-sm font-medium text-text group-hover:text-accent transition-colors">Email</p>
          <p class="text-sm text-text-dim">dvbattag@iu.edu</p>
        </div>
      </a>

      <a
        href="https://linkedin.com/in/nickvbattaglia"
        target="_blank"
        rel="noopener"
        class="card flex items-center gap-4 hover:border-accent/40 group"
      >
        <span class="text-2xl">in</span>
        <div>
          <p class="text-sm font-medium text-text group-hover:text-accent transition-colors">LinkedIn</p>
          <p class="text-sm text-text-dim">linkedin.com/in/nickvbattaglia</p>
        </div>
      </a>

      <a
        href="https://github.com/nick-battags"
        target="_blank"
        rel="noopener"
        class="card flex items-center gap-4 hover:border-accent/40 group"
      >
        <span class="text-2xl">⊙</span>
        <div>
          <p class="text-sm font-medium text-text group-hover:text-accent transition-colors">GitHub</p>
          <p class="text-sm text-text-dim">github.com/nick-battags</p>
        </div>
      </a>
    </div>
  </section>

</Layout>
