---
// CTA card linking to the live Argus Hub — shown on /projects/lawagent
---

<div class="rounded-xl border border-accent/30 bg-accent-dim p-7 mt-10">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-5">
    <div>
      <p class="text-xs text-accent uppercase tracking-widest font-medium mb-1.5">Live demo</p>
      <h3 class="font-serif text-xl font-semibold text-text mb-2">
        Drafting &amp; Review Hub
      </h3>
      <p class="text-sm text-text-dim leading-relaxed max-w-md">
        Generate a contract from a prompt, revise your draft, or review an existing agreement
        — with AI-powered issue spotting, missing-clause proposals, and per-change accept/reject controls.
      </p>
    </div>
    <a
      href="https://lawagent.nickvbattaglia.com/hub"
      target="_blank"
      rel="noopener"
      class="btn-primary shrink-0 whitespace-nowrap"
    >
      Open the Hub →
    </a>
  </div>
  <div class="mt-5 flex flex-wrap gap-1.5">
    <span class="pill">Gemini 2.5 Flash</span>
    <span class="pill">Cohere Rerank 3.5</span>
    <span class="pill">Neon pgvector</span>
    <span class="pill">Supermemory</span>
    <span class="pill">Cloud Run</span>
  </div>
</div>
